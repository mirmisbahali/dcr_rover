<launch>

  <arg name="serial_port" default="/dev/ttyUSB0"/>

  <!-- WebSocket bridge so the base station GUI can connect via roslib -->
  <node pkg="rosbridge_server" exec="rosbridge_websocket" name="rosbridge_websocket" output="screen">
    <param name="port" value="9090"/>
  </node>

  <!-- SocketCAN bridge - exposes CAN bus as socketcan_bridge/tx|rx topics -->
  <node pkg="nobleo_socketcan_bridge" exec="socketcan_bridge" name="socketcan_bridge" output="screen">
    <param name="interface" value="can1"/>
  </node>

  <!-- Robot state publisher - converts /joint_states to /tf for Foxglove visualisation -->
  <node pkg="robot_state_publisher" exec="robot_state_publisher" name="robot_state_publisher" output="screen">
    <param name="robot_description" value="$(command 'cat $(find-pkg-share motor_node)/urdf/arm.urdf')"/>
  </node>

  <!-- Robotic arm controller (FK/IK, 6-DOF, subscribes /joy + socketcan_bridge/rx) -->
  <node pkg="motor_node" exec="start_controller" name="motor_controller" output="screen"/>

  <!-- Drivetrain RS485 motor service (/motor_rs485_service/issue_motor_command) -->
  <node pkg="dcr_motor_controller" exec="controller" name="motor_rs485_service" output="screen"/>

  <!-- Teleop bridge: maps /joy axes[1]/axes[3] to drivetrain motor service calls -->
  <node pkg="dcr_joy_to_motor" exec="teleop" name="teleop" output="screen"/>

  <!-- HTTP MJPEG video server - serves ROS image topics to the GUI on port 8080 -->
  <node pkg="web_video_server" exec="web_video_server" name="web_video_server" output="screen">
    <param name="port" value="8080"/>
  </node>

  <!-- Camera nodes - edit config/cameras.yaml to set the correct /dev/videoX paths -->
  <node pkg="rover_camera" exec="camera_node" name="camera1" output="screen">
    <param from="$(find-pkg-share rover_bringup)/config/cameras.yaml"/>
    <remap from="image_raw" to="/camera1/image_raw"/>
  </node>

  <node pkg="rover_camera" exec="camera_node" name="camera2" output="screen">
    <param from="$(find-pkg-share rover_bringup)/config/cameras.yaml"/>
    <remap from="image_raw" to="/camera2/image_raw"/>
  </node>

  <node pkg="rover_camera" exec="camera_node" name="camera3" output="screen">
    <param from="$(find-pkg-share rover_bringup)/config/cameras.yaml"/>
    <remap from="image_raw" to="/camera3/image_raw"/>
  </node>

  <!-- Antenna serial bridge - forwards /antenna/trigger chars to ESP32 over USB serial -->
  <node pkg="rover_antenna" exec="antenna_node" name="antenna_node" output="screen">
    <param name="serial_port" value="$(var serial_port)"/>
    <param name="baud_rate" value="115200"/>
  </node>

</launch>
